{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "VEH: Launch test_target",
            "type": "veh",
            "request": "launch",
            "program": "${workspaceFolder}/build/Release/test_target.exe",
            "stopOnEntry": true
        },
        {
            "name": "VEH: Attach to PID",
            "type": "veh",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "logFile": "D:/News/Hack/Engine/VEHDebugger/for VSCode Extension/test/veh-adapter.log",
            "logLevel": "debug"
        }
    ]
}
